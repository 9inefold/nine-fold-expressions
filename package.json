{
	"name": "nine-fold-expressions",
	"version": "0.0.1",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm run build-mono && vite build",
		"deploy": "gh-pages -d build -t true",
		"preview": "vite preview",
		"build-mono": "tsc --build packages/rehype-mod-code",
		"test": "pnpm run test:integration && pnpm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:integration": "playwright test",
		"test:unit": "vitest"
	},
	"dependencies": {
		"@plugin/rehype-mod-code": "workspace:*"
	},
	"devDependencies": {
		"@iconify/svelte": "^4.0.2",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/adapter-static": "^2.0.3",
		"@sveltejs/kit": "^1.20.4",
		"@types/dateformat": "^5.0.2",
		"@types/hast": "^3.0.4",
		"dateformat": "^5.0.3",
		"mdsvex": "^0.11.2",
		"postcss": "^8.4.40",
		"postcss-load-config": "^6.0.1",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"remark-code-extra": "^1.0.1",
		"sass": "^1.67.0",
		"striptags": "^3.2.0",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"svelte-preprocess": "^6.0.2",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0",
		"vite": "^4.4.2",
		"vitest": "^0.32.2"
	},
	"type": "module",
	"pnpm": {
		"overrides": {
			"get-func-name@<2.0.1": ">=2.0.1",
			"vite@>=4.4.0 <4.4.12": ">=4.4.12",
			"vite@>=4.0.0 <=4.5.1": ">=4.5.2",
			"undici@<5.26.2": ">=5.26.2",
			"vite@>=4.0.0 <=4.5.2": ">=4.5.3",
			"undici@<5.28.4": ">=5.28.4",
			"undici@<=5.28.2": ">=5.28.3",
			"braces@<3.0.3": ">=3.0.3",
			"micromatch@<4.0.8": ">=4.0.8",
			"svelte@<4.2.19": ">=4.2.19",
			"vite@>=4.0.0 <4.5.4": ">=4.5.4",
			"vite@>=4.0.0 <=4.5.3": ">=4.5.4",
			"rollup@>=3.0.0 <3.29.5": ">=3.29.5",
			"@sveltejs/kit@<2.8.3": ">=2.8.3",
			"nanoid@<3.3.8": ">=3.3.8",
			"undici@>=4.5.0 <5.28.5": ">=5.28.5",
			"esbuild@<=0.24.2": ">=0.25.0",
			"vite@<=4.5.5": ">=4.5.6",
			"vite@<4.5.10": ">=4.5.10",
			"vite@<4.5.11": ">=4.5.11",
			"vite@<4.5.13": ">=4.5.13",
			"cookie@<0.7.0": ">=0.7.0",
			"vite@<=4.5.13": ">=4.5.14",
			"vite@<4.5.12": ">=4.5.12",
			"undici@<5.29.0": ">=5.29.0",
			"brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
			"prismjs@<1.30.0": ">=1.30.0",
			"devalue@<5.3.2": ">=5.3.2",
			"vite@<=5.4.19": ">=5.4.20"
		}
	}
}
